modules = ["nodejs-24", "python-base-3.13"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Bot Panel"

[[workflows.workflow]]
name = "Bot Panel"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd bot-panel && pip install -r requirements.txt -q && python app.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["freetype", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "tcl", "tk", "zlib"]

[userenv]

[userenv.shared]
ADMIN_USERNAME = "admin"
BOT_PREFIX = "!"
BOT_TIMEZONE = "UTC"
FLASK_ENV = "development"
LAVALINK_PORT = "2333"
LAVALINK_SSL = "false"
PANEL_PORT = "5000"
